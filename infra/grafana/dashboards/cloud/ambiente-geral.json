{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["cloud", "ambiente"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ambiente Geral — Cloud",
  "uid": "cloud-ambiente-geral",
  "version": 1,
  "weekStart": "",
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Produção — Vercel Serverless",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 3 },
      "options": {
        "mode": "markdown",
        "content": "Scrape direto de `https://controle-de-acesso-pi.vercel.app/metrics` via job `controle-de-acesso-prod` no Prometheus local. Como Vercel roda múltiplas instâncias serverless, gauges (memória/CPU) refletem a instância que respondeu ao último scrape. Counters reiniciam a cada cold-start."
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Serviços UP",
      "datasource": { "type": "prometheus", "uid": "prom-cloud" },
      "gridPos": { "x": 0, "y": 3, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "noValue": "—"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(up{job=\"controle-de-acesso-prod\"} == 1)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-cloud" }
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Serviços DOWN",
      "datasource": { "type": "prometheus", "uid": "prom-cloud" },
      "gridPos": { "x": 6, "y": 3, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "—"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "count(up{job=\"controle-de-acesso-prod\"} == 0) OR on() vector(0)",
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prom-cloud" }
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Status por target",
      "datasource": { "type": "prometheus", "uid": "prom-cloud" },
      "gridPos": { "x": 12, "y": 3, "w": 12, "h": 8 },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false, "reducer": ["sum"], "fields": "" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "up{job=\"controle-de-acesso-prod\"}",
          "refId": "A",
          "instant": true,
          "format": "table",
          "datasource": { "type": "prometheus", "uid": "prom-cloud" }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "indexByName": {},
            "renameByName": { "Value": "Status" }
          }
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latência de scrape (p95)",
      "datasource": { "type": "prometheus", "uid": "prom-cloud" },
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "scrape_duration_seconds{job=\"controle-de-acesso-prod\"}",
          "refId": "A",
          "legendFormat": "{{instance}}",
          "datasource": { "type": "prometheus", "uid": "prom-cloud" }
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memória residente",
      "datasource": { "type": "prometheus", "uid": "prom-cloud" },
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "spanNulls": false
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"controle-de-acesso-prod\"}",
          "refId": "A",
          "legendFormat": "{{instance}}",
          "datasource": { "type": "prometheus", "uid": "prom-cloud" }
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU (rate 1m)",
      "datasource": { "type": "prometheus", "uid": "prom-cloud" },
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"controle-de-acesso-prod\"}[1m])",
          "refId": "A",
          "legendFormat": "{{instance}}",
          "datasource": { "type": "prometheus", "uid": "prom-cloud" }
        }
      ]
    }
  ]
}
