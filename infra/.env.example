# ─── infra/.env ────────────────────────────────────────────────────────────
# Variáveis lidas EXCLUSIVAMENTE pelo docker-compose desta pasta.
# Copiar para `infra/.env` e ajustar antes do `docker compose up`.
# NUNCA commitar `infra/.env` — já coberto pelo .gitignore raiz.

# ─── MongoDB ───────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=ca_admin
MONGO_INITDB_ROOT_PASSWORD=trocar-antes-de-subir

# ─── Redis ─────────────────────────────────────────────────────────────────
# Se mudar aqui, atualizar também REDIS_URL no .env raiz da aplicação.
REDIS_PASSWORD=trocar-antes-de-subir

# ─── Grafana ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=trocar-antes-de-subir

# Webhook que recebe os alertas do Grafana (Slack/Discord incoming webhook,
# ngrok URL pra dev, etc). Placeholder para ambiente local — alertas firam
# mas a entrega falha silenciosamente.
ALERT_WEBHOOK_URL=http://localhost:9999/alerts

# ─── App (container) ───────────────────────────────────────────────────────
# JWT_SECRET DEVE ter ≥32 chars. Gerar com: openssl rand -hex 32
JWT_SECRET=trocar-antes-de-subir-32-chars-min-trocar-antes
JWT_EXPIRES_IN=15m
HASH_ITERATIONS=100000
HASH_KEYLEN=64
HASH_DIGEST=sha512

# Lista de origens permitidas (sem espaços, separadas por vírgula).
# Vazio = sem CORS (clientes não-browser ainda funcionam).
# Em produção, definir explicitamente — NÃO usar origin '*'.
CORS_ORIGIN=
