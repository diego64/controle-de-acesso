# ─── Aplicação ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Banco de dados ────────────────────────────────────────────────────────
# Credenciais devem bater com infra/.env (MONGO_INITDB_ROOT_USERNAME / _PASSWORD).
# Para Mongo com auth root, usar `?authSource=admin`.
MONGODB_URI=mongodb://ca_admin:trocar-antes-de-subir@localhost:27017/controle-de-acesso?authSource=admin

# ─── Cache / Blocklist JWT ─────────────────────────────────────────────────
# Senha deve bater com REDIS_PASSWORD em infra/.env.
REDIS_URL=redis://default:trocar-antes-de-subir@localhost:6379

# ─── JWT ───────────────────────────────────────────────────────────────────
# JWT_SECRET DEVE ter no mínimo 32 caracteres (validado por Zod no boot).
JWT_SECRET=changeme-32-chars-min-changeme-32-chars-min
JWT_EXPIRES_IN=15m

# ─── Hash de senha (PBKDF2 via node:crypto) ────────────────────────────────
HASH_ITERATIONS=100000
HASH_KEYLEN=64
HASH_DIGEST=sha512

# ─── CORS ──────────────────────────────────────────────────────────────────
# Lista separada por vírgula de origens permitidas (sem espaços).
# Vazio = plugin NÃO registrado (acesso só de clientes não-browser).
# Exemplos:
#   dev:   CORS_ORIGIN=http://localhost:5173,http://localhost:3000
#   prod:  CORS_ORIGIN=https://app.example.com
CORS_ORIGIN=
