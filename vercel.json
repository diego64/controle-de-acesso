{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile --prod=false",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@5.1.0",
      "maxDuration": 10,
      "memory": 1024,
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "regions": ["gru1"],
  "env": {
    "NODE_ENV": "production"
  }
}
